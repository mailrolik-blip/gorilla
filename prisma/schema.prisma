datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TeamRole {
  PLAYER
  COACH
  CAPTAIN
  PARENT
}

enum TeamMemberStatus {
  ACTIVE
  INJURED
  SUSPENDED
}

enum StaffRole {
  MANAGER
  ADMIN
}

enum TeamApplicationStatus {
  PENDING
  IN_REVIEW
  ACCEPTED
  REJECTED
  CANCELLED
}

enum RentalSlotStatus {
  AVAILABLE
  BOOKED
  UNAVAILABLE
}

enum RentalBookingStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  CANCELLED
}

model User {
  id           Int     @id @default(autoincrement())
  email        String? @unique
  phone        String? @unique
  telegramId   String? @unique
  passwordHash String?
  staffRole    StaffRole?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles    UserProfile[]
  memberships TeamMember[]
  bookings       Booking[]       @relation("UserBookings")
  rentalBookings RentalBooking[] @relation("UserRentalBookings")
  reviewedTeamApplications TeamApplication[] @relation("ReviewedTeamApplications")
  trainings   SchoolTraining[] // как тренер
}

model UserProfile {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  profileType String
  firstName   String?
  lastName    String?
  birthDate   DateTime?

  parentId Int?
  parent   UserProfile?  @relation("ParentChild", fields: [parentId], references: [id])
  children UserProfile[] @relation("ParentChild")

  cityId Int?
  city   City? @relation(fields: [cityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings         Booking[]         @relation("UserProfileBookings")
  rentalBookings   RentalBooking[]
  trainingBookings TrainingBooking[]
  teamApplications TeamApplication[]
  teamMemberships  TeamMember[]
}

model Team {
  id          Int    @id @default(autoincrement())
  name        String
  slug        String? @unique
  description String?
  cityId      Int?
  city        City? @relation(fields: [cityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members TeamMember[]
  applications TeamApplication[]
}

model TeamMember {
  id           Int              @id @default(autoincrement())
  userId       Int?
  participantId Int?
  teamId       Int
  role         TeamRole
  status       TeamMemberStatus
  positionCode String?
  jerseyNumber Int?
  joinedAt     DateTime         @default(now())
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user        User?       @relation(fields: [userId], references: [id])
  participant UserProfile? @relation(fields: [participantId], references: [id])
  team        Team        @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
  @@unique([participantId, teamId])
  @@index([participantId])
}

model Session {
  id          Int     @id @default(autoincrement())
  title       String
  description String?

  startTime DateTime
  endTime   DateTime

  cityId Int?
  city   City? @relation(fields: [cityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
}

model Booking {
  id            Int @id @default(autoincrement())
  participantId Int
  sessionId     Int

  status String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participant UserProfile @relation("UserProfileBookings", fields: [participantId], references: [id])
  session     Session     @relation(fields: [sessionId], references: [id])

  user   User? @relation("UserBookings", fields: [userId], references: [id])
  userId Int?

  @@unique([participantId, sessionId])
}

model City {
  id   Int    @id @default(autoincrement())
  name String @unique

  profiles  UserProfile[]
  teams     Team[]
  sessions  Session[]
  trainings SchoolTraining[]
  rentalFacilities RentalFacility[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SchoolTraining {
  trainingId   Int    @id @default(autoincrement())
  name         String
  description  String?
  trainingType String

  cityId Int
  city   City @relation(fields: [cityId], references: [id])

  trainerId Int?
  trainer   User? @relation(fields: [trainerId], references: [id])

  startTime DateTime
  endTime   DateTime
  location  String

  capacity     Int      @default(20)   
  isActive     Boolean   @default(true) 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings TrainingBooking[]

  @@index([startTime])
  @@index([endTime])
  @@index([cityId])
}

model TrainingBooking {
  id            Int      @id @default(autoincrement())

  participantId Int
  trainingId    Int

  status        String   // booked, cancelled

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  participant   UserProfile    @relation(fields: [participantId], references: [id])
  training      SchoolTraining @relation(fields: [trainingId], references: [trainingId])

  @@unique([participantId, trainingId])
  @@index([participantId])
  @@index([trainingId])
}

model TeamApplication {
  id                   Int                   @id @default(autoincrement())
  participantId        Int
  teamId               Int
  reviewedById         Int?
  status               TeamApplicationStatus @default(PENDING)
  commentFromApplicant String?
  internalNote         String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  participant UserProfile @relation(fields: [participantId], references: [id])
  team        Team        @relation(fields: [teamId], references: [id])
  reviewedBy  User?       @relation("ReviewedTeamApplications", fields: [reviewedById], references: [id])

  @@index([participantId])
  @@index([teamId])
  @@index([reviewedById])
  @@index([status])
}

model RentalFacility {
  id        Int      @id @default(autoincrement())
  name      String
  cityId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city      City             @relation(fields: [cityId], references: [id])
  resources RentalResource[]

  @@index([cityId])
}

model RentalResource {
  id           Int      @id @default(autoincrement())
  facilityId   Int
  name         String
  resourceType String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  facility RentalFacility @relation(fields: [facilityId], references: [id])
  slots    RentalSlot[]

  @@index([facilityId])
}

model RentalSlot {
  id         Int              @id @default(autoincrement())
  resourceId Int
  startsAt   DateTime
  endsAt     DateTime
  status     RentalSlotStatus @default(AVAILABLE)
  isPublic   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  resource RentalResource @relation(fields: [resourceId], references: [id])
  bookings RentalBooking[]

  @@index([resourceId])
  @@index([startsAt])
  @@index([endsAt])
  @@index([status])
  @@index([isPublic])
}

model RentalBooking {
  id           Int                 @id @default(autoincrement())
  slotId        Int
  userId        Int
  participantId Int?
  status        RentalBookingStatus @default(PENDING_CONFIRMATION)
  noteFromUser  String?
  managerNote   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  slot        RentalSlot   @relation(fields: [slotId], references: [id])
  user        User         @relation("UserRentalBookings", fields: [userId], references: [id])
  participant UserProfile? @relation(fields: [participantId], references: [id])

  @@index([slotId])
  @@index([userId])
  @@index([participantId])
  @@index([status])
}
