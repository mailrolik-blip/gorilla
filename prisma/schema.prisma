datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TeamRole {
  PLAYER
  COACH
  CAPTAIN
  PARENT
}

enum TeamMemberStatus {
  ACTIVE
  INJURED
  SUSPENDED
}

model User {
  id           Int     @id @default(autoincrement())
  email        String? @unique
  phone        String? @unique
  telegramId   String? @unique
  passwordHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profiles    UserProfile[]
  memberships TeamMember[]
  bookings    Booking[]        @relation("UserBookings")
  trainings   SchoolTraining[] // как тренер
}

model UserProfile {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  profileType String
  firstName   String?
  lastName    String?
  birthDate   DateTime?

  parentId Int?
  parent   UserProfile?  @relation("ParentChild", fields: [parentId], references: [id])
  children UserProfile[] @relation("ParentChild")

  cityId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[] @relation("UserProfileBookings")
}

model Team {
  id     Int    @id @default(autoincrement())
  name   String
  cityId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members TeamMember[]
}

model TeamMember {
  id        Int              @id @default(autoincrement())
  userId    Int
  teamId    Int
  role      TeamRole
  status    TeamMemberStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])

  @@unique([userId, teamId])
}

model Session {
  id          Int     @id @default(autoincrement())
  title       String
  description String?

  startTime DateTime
  endTime   DateTime

  cityId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
}

model Booking {
  id            Int @id @default(autoincrement())
  participantId Int
  sessionId     Int

  status String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participant UserProfile @relation("UserProfileBookings", fields: [participantId], references: [id])
  session     Session     @relation(fields: [sessionId], references: [id])

  user   User? @relation("UserBookings", fields: [userId], references: [id])
  userId Int?

  @@unique([participantId, sessionId])
}

model City {
  id   Int    @id @default(autoincrement())
  name String @unique

  trainings SchoolTraining[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SchoolTraining {
  trainingId   Int    @id @default(autoincrement())
  name         String
  description  String
  trainingType String

  cityId Int
  city   City @relation(fields: [cityId], references: [id])

  trainerId Int?
  trainer   User? @relation(fields: [trainerId], references: [id])

  startTime DateTime
  endTime   DateTime
  location  String

  capacity     Int      @default(20)   
  isActive     Boolean   @default(true) 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startTime])
  @@index([endTime])
  @@index([cityId])
}

model TrainingBooking {
  id            Int      @id @default(autoincrement())

  participantId Int
  trainingId    Int

  status        String   // booked, cancelled

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  participant   UserProfile   @relation(fields: [participantId], references: [id])
  training      SchoolTraining @relation(fields: [trainingId], references: [trainingId])

  @@unique([participantId, trainingId])
}